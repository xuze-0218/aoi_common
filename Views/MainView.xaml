<Window
    x:Class="aoi_common.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:aoi_common"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:vpro="clr-namespace:Cognex.VisionPro;assembly=Cognex.VisionPro.Controls"
    xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
    Title="AOI视觉检测系统"
    Width="1280"
    Height="800"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="3" />
            <RowDefinition Height="200" MinHeight="150" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="配置">
                <MenuItem Command="{Binding OpenDebugCommand}" Header="程序调试" />
                <MenuItem Command="{Binding ParaDebugCommand}" Header="参数配置" />
                <MenuItem Command="{Binding CommunicateDebugCommand}" Header="通讯配置" />
            </MenuItem>
            <MenuItem Header="工具" />
        </Menu>

        <StackPanel
            Grid.Row="1"
            Background="#2D2D30"
            Orientation="Horizontal">
            <Button
                Width="100"
                Height="30"
                Margin="5"
                Command="{Binding ImportImageCommand}"
                Content="导入图片" />
            <Button
                Width="100"
                Height="30"
                Margin="5"
                Background="Green"
                Command="{Binding RunCommand}"
                Content="单次测试"
                Foreground="White" />
            <Button
                Width="100"
                Height="30"
                Margin="5"
                Background="Red"
                Command="{Binding StopCommand}"
                Content="停止检测"
                Foreground="White" />

            <Separator Margin="10,5" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" />

            <TextBlock
                Margin="10,0"
                VerticalAlignment="Center"
                Foreground="White">
                状态:<Run Foreground="LightGreen" Text="{Binding Status}" />
            </TextBlock>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <WindowsFormsHost Grid.Column="0" Margin="5">
                <vpro:CogRecordDisplay x:Name="mainRecordDisplay" />
            </WindowsFormsHost>

            <Grid Grid.Column="1" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.5*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Background="#252526"
                    BorderBrush="#555"
                    BorderThickness="1"
                    CornerRadius="5">
                    <Viewbox Margin="20">
                        <TextBlock
                            FontWeight="Bold"
                            Foreground="LimeGreen"
                            Text="{Binding CurrentResultText, FallbackValue='READY'}" />
                    </Viewbox>
                </Border>

                <StackPanel Grid.Row="1" Margin="0,10,0,0">
                    <GroupBox
                        BorderBrush="#555"
                        Foreground="White"
                        Header="统计数据">
                        <UniformGrid
                            Margin="5"
                            Background="Gray"
                            Columns="2">
                            <StackPanel Margin="5">
                                <TextBlock
                                    FontSize="14"
                                    Foreground="Cyan"
                                    Text="Total" />
                                <TextBlock
                                    FontSize="24"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="{Binding TotalCount}" />
                            </StackPanel>
                            <StackPanel Margin="5">
                                <TextBlock
                                    FontSize="14"
                                    Foreground="Lime"
                                    Text="OK" />
                                <TextBlock
                                    FontSize="24"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="{Binding OkCount}" />
                            </StackPanel>
                            <StackPanel Margin="5">
                                <TextBlock
                                    FontSize="14"
                                    Foreground="Red"
                                    Text="NG" />
                                <TextBlock
                                    FontSize="24"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="{Binding NgCount}" />
                            </StackPanel>
                            <StackPanel Margin="5">
                                <TextBlock
                                    FontSize="14"
                                    Foreground="Yellow"
                                    Text="Ratio" />
                                <TextBlock
                                    FontSize="24"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="{Binding YieldRate}" />
                            </StackPanel>
                        </UniformGrid>
                    </GroupBox>
                </StackPanel>
            </Grid>
        </Grid>

        <GridSplitter
            Grid.Row="3"
            Height="3"
            HorizontalAlignment="Stretch"
            Background="#333" />

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <GroupBox
                Grid.Column="0"
                BorderBrush="#555"
                Foreground="White"
                Header="历史检测图">
                <ListBox
                    Background="Black"
                    BorderThickness="0"
                    ItemsSource="{Binding HistoryImages}"
                    SelectedItem="{Binding SelectedHistoryImage}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="2"
                                BorderBrush="{Binding ResultColor}"
                                BorderThickness="2">
                                <Grid Width="160" Height="120">
                                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                                    <TextBlock
                                        Padding="2"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Background="#88000000"
                                        Foreground="White"
                                        Text="{Binding Result}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>

            <GridSplitter
                Grid.Column="1"
                Width="3"
                VerticalAlignment="Stretch"
                Background="#333" />

            <GroupBox
                Grid.Column="2"
                BorderBrush="#555"
                Foreground="White"
                Header="系统日志">
                <DataGrid
                    AutoGenerateColumns="False"
                    Background="AliceBlue"
                    BorderThickness="0"
                    IsReadOnly="True"
                    ItemsSource="{Binding LogSource}"
                    RowHeaderWidth="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="80"
                            Binding="{Binding Timestamp}"
                            Header="时间" />
                        <DataGridTextColumn
                            Width="50"
                            Binding="{Binding Level}"
                            Header="级别">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{Binding Color}" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding Message}"
                            Header="内容" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>
    </Grid>
</Window>