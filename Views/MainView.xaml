<Window
    x:Class="aoi_common.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:aoi_common"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:vpro="clr-namespace:Cognex.VisionPro;assembly=Cognex.VisionPro.Controls"
    xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
    Title="AOI视觉检测系统"
    Width="1280"
    Height="800"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">

    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="3" />
            <RowDefinition Height="200" MinHeight="150" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="配置">
                <MenuItem Command="{Binding OpenDebugCommand}" Header="程序调试" />
                <MenuItem Command="{Binding CameraDebugCommand}" Header="相机调试" />
                <MenuItem Command="{Binding ParaDebugCommand}" Header="参数配置" />
                <MenuItem Command="{Binding CommunicateDebugCommand}" Header="通讯配置" />
            </MenuItem>
            <MenuItem Header="工具" />
        </Menu>

        <StackPanel
            Grid.Row="1"
            Height="50"
            Margin="0"
            Background="#F0F0F0"
            Orientation="Horizontal">

            <Button
                Width="110"
                Height="40"
                Margin="0,0,8,0"
                Background="#28A745"
                Command="{Binding OfflineSingleImageCommand}"
                Content="⏸ 离线单张"
                FontSize="12"
                FontWeight="Bold"
                Foreground="Black"
                ToolTip="选择单张本地图像进行离线测试" />

            <Button
                Width="110"
                Height="40"
                Margin="0,0,8,0"
                Background="#28A745"
                Command="{Binding OfflineFolderBatchCommand}"
                Content="⏸ 离线文件夹"
                FontSize="12"
                FontWeight="Bold"
                Foreground="Black"
                ToolTip="选择文件夹进行批量离线测试" />

            <Button
                Width="110"
                Height="40"
                Margin="0,0,8,0"
                Background="#28A745"
                Command="{Binding OnlineStartCommand, UpdateSourceTrigger=PropertyChanged}"
                Content="▶ 启动"
                FontSize="12"
                FontWeight="Bold"
                Foreground="Black"
                ToolTip="启动在线模式，等待 PLC 信号" />

            <Button
                Width="110"
                Height="40"
                Margin="0,0,8,0"
                Background="#FFC107"
                Command="{Binding SnapCommand}"
                Content="📷拍照测试"
                FontSize="12"
                FontWeight="Bold"
                Foreground="Black"
                IsEnabled="{Binding IsOnlineRunning}"
                ToolTip="在线模式下手动触发一次拍照检测">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#999999" />
                                <Setter Property="Foreground" Value="#CCCCCC" />
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button
                Width="110"
                Height="40"
                Margin="0,0,20,0"
                Background="#DC3545"
                Command="{Binding OnlineStopCommand, UpdateSourceTrigger=PropertyChanged}"
                Content="⏹ 停止"
                FontSize="12"
                FontWeight="Bold"
                Foreground="Black"
                IsEnabled="{Binding IsOnlineRunning, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                ToolTip="停止在线模式" />

            <TextBlock
                VerticalAlignment="Center"
                FontSize="13"
                FontWeight="Bold"
                Foreground="#333"
                Text="{Binding ModeIndicator}" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <WindowsFormsHost Grid.Column="0" Margin="5">
                <vpro:CogRecordDisplay x:Name="mainRecordDisplay" />
            </WindowsFormsHost>

            <Grid Grid.Column="1" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.5*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Background="#252526"
                    BorderBrush="#555"
                    BorderThickness="1"
                    CornerRadius="5">
                    <Viewbox Margin="20">
                        <TextBlock
                            FontWeight="Bold"
                            Foreground="LimeGreen"
                            Text="READY" />
                    </Viewbox>
                </Border>

                <StackPanel Grid.Row="1" Margin="0,10,0,0">
                    <GroupBox
                        BorderBrush="#555"
                        Foreground="White"
                        Header="统计数据">
                        <UniformGrid
                            Margin="5"
                            Background="Gray"
                            Columns="2">
                            <StackPanel Margin="5">
                                <TextBlock
                                    FontSize="14"
                                    Foreground="Cyan"
                                    Text="Total" />
                                <TextBlock
                                    FontSize="24"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="0" />
                            </StackPanel>
                            <StackPanel Margin="5">
                                <TextBlock
                                    FontSize="14"
                                    Foreground="Lime"
                                    Text="OK" />
                                <TextBlock
                                    FontSize="24"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="0" />
                            </StackPanel>
                            <StackPanel Margin="5">
                                <TextBlock
                                    FontSize="14"
                                    Foreground="Red"
                                    Text="NG" />
                                <TextBlock
                                    FontSize="24"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="0" />
                            </StackPanel>
                            <StackPanel Margin="5">
                                <TextBlock
                                    FontSize="14"
                                    Foreground="Yellow"
                                    Text="Ratio" />
                                <TextBlock
                                    FontSize="24"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="0%" />
                            </StackPanel>
                        </UniformGrid>
                    </GroupBox>
                </StackPanel>
            </Grid>
        </Grid>

        <GridSplitter
            Grid.Row="3"
            Height="3"
            HorizontalAlignment="Stretch"
            Background="#333" />

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <GroupBox
                Grid.Column="0"
                BorderBrush="#555"
                Foreground="White"
                Header="历史检测图">
                <ListBox Background="Black" BorderThickness="0">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </GroupBox>

            <GridSplitter
                Grid.Column="1"
                Width="3"
                VerticalAlignment="Stretch"
                Background="#333" />

            <GroupBox
                Grid.Column="2"
                BorderBrush="#555"
                Foreground="White"
                Header="系统日志">
                <DataGrid
                    AutoGenerateColumns="False"
                    Background="AliceBlue"
                    BorderThickness="0"
                    IsReadOnly="True"
                    ItemsSource="{Binding LogSource}"
                    RowHeaderWidth="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="80"
                            Binding="{Binding Timestamp}"
                            Header="时间" />
                        <DataGridTextColumn
                            Width="50"
                            Binding="{Binding Level}"
                            Header="级别">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{Binding Color}" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding Message}"
                            Header="内容" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>
    </Grid>
</Window>