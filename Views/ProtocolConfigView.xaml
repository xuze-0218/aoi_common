<UserControl
    x:Class="aoi_common.Views.ProtocolConfigView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:aoi_common.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Margin="10" Background="AliceBlue">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="1.5*" />
        </Grid.ColumnDefinitions>

        <GroupBox
            Margin="5"
            Background="White"
            Header="接收解析 (Input Parser)">
            <DataGrid
                AutoGenerateColumns="False"
                CanUserAddRows="True"
                ItemsSource="{Binding InputFields}">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Name}"
                        Header="变量名" />
                    <DataGridTextColumn
                        Width="60"
                        Binding="{Binding StartIndex}"
                        Header="起始位" />
                    <DataGridTextColumn
                        Width="60"
                        Binding="{Binding Length}"
                        Header="长度" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GroupBox
            Grid.Column="1"
            Margin="5"
            Background="White"
            Header="发送拼装 (Output Assembler)">
            <DockPanel>
                <StackPanel
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Bottom"
                    Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Text="总长度预览: " />
                    <TextBlock
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        FontWeight="Bold"
                        Foreground="Blue"
                        Text="{Binding TotalLength}" />
                    <Button
                        Width="80"
                        Margin="5"
                        Command="{Binding SortCommand}"
                        Content="按索引重排" />
                </StackPanel>

                <DataGrid
                    AutoGenerateColumns="False"
                    CanUserAddRows="True"
                    ItemsSource="{Binding OutputFields}">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="40"
                            Binding="{Binding Index}"
                            Header="索引" />

                        <DataGridComboBoxColumn
                            Width="80"
                            Header="来源类型"
                            ItemsSource="{Binding SourceTypes}"
                            SelectedItemBinding="{Binding Source}" />

                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding NameOrValue}"
                            Header="变量名/固定值" />

                        <DataGridTextColumn
                            Width="50"
                            Binding="{Binding Length}"
                            Header="长度" />
                        <DataGridTextColumn
                            Width="50"
                            Binding="{Binding Scale}"
                            Header="倍率" />

                        <DataGridTextColumn
                            Width="80"
                            Binding="{Binding Preview}"
                            Foreground="Gray"
                            Header="预览"
                            IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </GroupBox>
    </Grid>
</UserControl>
