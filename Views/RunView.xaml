<UserControl
    x:Class="aoi_common.Views.RunView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cognex="clr-namespace:Cognex.VisionPro;assembly=Cognex.VisionPro.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:aoi_common.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
    d:DesignHeight="450"
    d:DesignWidth="800"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <Grid Background="Black">
        <wfi:WindowsFormsHost>
            <cognex:CogRecordDisplay x:Name="cogRecordDisplay" Dock="Fill" />
        </wfi:WindowsFormsHost>
    </Grid>
</UserControl>
