<UserControl
    x:Class="aoi_common.Views.CommunicationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:comm="clr-namespace:aoi_common.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:aoi_common.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    d:DesignHeight="450"
    d:DesignWidth="800"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ObjectDataProvider
            x:Key="CommProtocolEnum"
            MethodName="GetValues"
            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="comm:CommProtocol" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <ObjectDataProvider
            x:Key="CommRoleEnum"
            MethodName="GetValues"
            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="comm:CommRole" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>
    <Grid Margin="10" Background="AliceBlue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <GroupBox Padding="5" Header="通讯设置">
            <WrapPanel>
                <StackPanel Margin="5">
                    <TextBlock Text="协议:" />
                    <ComboBox
                        Width="80"
                        ItemsSource="{Binding Source={StaticResource CommProtocolEnum}}"
                        SelectedItem="{Binding SelectedProtocol}" />
                </StackPanel>
                <StackPanel Margin="5">
                    <TextBlock Text="模式:" />
                    <ComboBox
                        Width="80"
                        ItemsSource="{Binding Source={StaticResource CommRoleEnum}}"
                        SelectedItem="{Binding SelectedRole}" />
                </StackPanel>
                <StackPanel Margin="5">
                    <TextBlock Text="IP地址:" />
                    <TextBox Width="120" Text="{Binding Ip}" />
                </StackPanel>
                <StackPanel Margin="5">
                    <TextBlock Text="端口:" />
                    <TextBox Width="60" Text="{Binding Port}" />
                </StackPanel>
                <Button
                    Width="70"
                    Height="30"
                    Margin="5,15,5,0"
                    Background="LightGreen"
                    Command="{Binding StartCommand}"
                    Content="开启" />
                <Button
                    Width="70"
                    Height="30"
                    Margin="5,15,5,0"
                    Background="LightPink"
                    Command="{Binding StopCommand}"
                    Content="关闭" />
            </WrapPanel>
        </GroupBox>

        <ListBox
            Grid.Row="1"
            Margin="0,10,0,0"
            Background="#333"
            Foreground="White"
            ItemsSource="{Binding Logs}" />
    </Grid>
</UserControl>
