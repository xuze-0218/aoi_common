<UserControl
    x:Class="aoi_common.Views.CommunicationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:comm="clr-namespace:aoi_common.Models"
    xmlns:common="clr-namespace:aoi_common.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:aoi_common.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    MinWidth="600"
    MinHeight="600"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ObjectDataProvider
            x:Key="CommProtocolEnum"
            MethodName="GetValues"
            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="comm:CommProtocol" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <ObjectDataProvider
            x:Key="CommRoleEnum"
            MethodName="GetValues"
            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="comm:CommRole" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <common:BoolToColorConverter x:Key="BoolToColorConverter" />
    </UserControl.Resources>

    <Grid Margin="10" Background="AliceBlue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <GroupBox
            Grid.Row="0"
            Padding="10"
            Header="通讯设置">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="协议:" />
                <ComboBox
                    Grid.Column="1"
                    Margin="5,0,0,0"
                    ItemsSource="{Binding Source={StaticResource CommProtocolEnum}}"
                    SelectedItem="{Binding SelectedProtocol}" />

                <TextBlock
                    Grid.Column="2"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Text="模式:" />
                <ComboBox
                    Grid.Column="3"
                    Margin="5,0,0,0"
                    ItemsSource="{Binding Source={StaticResource CommRoleEnum}}"
                    SelectedItem="{Binding SelectedRole}" />

                <TextBlock
                    Grid.Column="4"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Text="IP:" />
                <TextBox
                    Grid.Column="5"
                    Margin="5,0,0,0"
                    Text="{Binding Ip}" />

                <TextBlock
                    Grid.Column="6"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Text="端口:" />
                <TextBox
                    Grid.Column="7"
                    Margin="5,0,0,0"
                    Text="{Binding Port}" />

                <TextBlock
                    Grid.Column="8"
                    Margin="20,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}}"
                    Text="{Binding StatusMessage}" />
            </Grid>
        </GroupBox>

        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="3" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox
                Grid.Column="0"
                Padding="5"
                Header="发送消息">
                <TextBox
                    Grid.Row="0"
                    AcceptsReturn="True"
                    Text="{Binding MessageInput, UpdateSourceTrigger=PropertyChanged}" />
            </GroupBox>

            <GridSplitter
                Grid.Column="1"
                Width="5"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch"
                Background="#999" />

            <GroupBox
                Grid.Column="2"
                Padding="5"
                Header="接收消息">
                <ListBox
                    Background="#2D2D30"
                    Foreground="White"
                    ItemsSource="{Binding ReceivedMessages}"
                    ScrollViewer.CanContentScroll="False">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock
                                Margin="0,2"
                                Foreground="Cyan"
                                Text="{Binding DisplayText}"
                                TextWrapping="Wrap" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>
        </Grid>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBox
                Grid.Row="0"
                AcceptsReturn="True"
                Text="{Binding MessageInput}" />

            <WrapPanel
                Grid.Row="1"
                Margin="0,5,0,0"
                HorizontalAlignment="Right">
                <Button
                    Width="80"
                    Height="30"
                    Margin="5"
                    Background="LimeGreen"
                    Command="{Binding SendCommand}"
                    Content="发送"
                    Foreground="White" />

                <Button
                    Width="80"
                    Height="30"
                    Margin="5"
                    Background="LightGreen"
                    Command="{Binding ConnectCommand}"
                    Content="连接"
                    Foreground="Black" />

                <Button
                    Width="80"
                    Height="30"
                    Margin="5"
                    Background="LightPink"
                    Command="{Binding DisconnectCommand}"
                    Content="断开"
                    Foreground="Black" />

                <Button
                    Width="80"
                    Height="30"
                    Margin="5"
                    Background="LightBlue"
                    Command="{Binding SaveConfigCommand}"
                    Content="保存"
                    Foreground="Black" />

                <Button
                    Width="80"
                    Height="30"
                    Margin="5"
                    Background="LightGray"
                    Command="{Binding ClearCommand}"
                    Content="清空"
                    Foreground="Black" />
            </WrapPanel>
        </Grid>
    </Grid>
</UserControl>